{
  "id": "aiir-ai-authored-disallowed",
  "meta": {
    "description": "Fails when an AIIR receipt marks the attested commit as AI-authored or omits authorship status"
  },
  "tenets": [
    {
      // Support both the legacy v1 URI and the current wrapped v2 URI.
      "predicates": {
        "types": [
          "https://invariantsystems.io/predicates/aiir/commit_receipt/v1",
          "https://invariantsystems.io/predicates/aiir/commit_receipt/v2"
        ]
      },
      "outputs": {
        "hasAiAuthoredStatus": {
          "code": "has(predicate.data.ai_attestation) && has(predicate.data.ai_attestation.is_ai_authored)"
        },
        "isAiAuthored": {
          "code": "has(predicate.data.ai_attestation) && has(predicate.data.ai_attestation.is_ai_authored) ? predicate.data.ai_attestation.is_ai_authored : false"
        },
        "authorshipClass": {
          "code": "has(predicate.data.ai_attestation) && has(predicate.data.ai_attestation.authorship_class) ? predicate.data.ai_attestation.authorship_class : ''"
        }
      },
      "code": "outputs.hasAiAuthoredStatus && !outputs.isAiAuthored",
      "assessment": {
        "message": "AIIR receipt reports no AI-authored content"
      },
      "error": {
        "message": "AI-authored content detected by AIIR or authorship status is missing",
        "guidance": "This repo only accepts revisions whose AIIR receipt reports a non-AI authorship status"
      }
    }
  ]
}
